#!/usr/bin/env bash
# install — 将 sense 技能包安装到 Claude Code
# 用法：./install [选项]
#   --list     列出所有可安装的技能
#   --remove   卸载已安装的技能
#   --help     显示帮助信息

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_DIR="$SCRIPT_DIR/skills"
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"

# 颜色输出
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

info()    { echo -e "${GREEN}[✓]${NC} $1"; }
warn()    { echo -e "${YELLOW}[!]${NC} $1"; }
error()   { echo -e "${RED}[✗]${NC} $1"; }

usage() {
  cat <<EOF
sense 技能包安装脚本

用法：
  ./install           安装所有技能到 Claude Code
  ./install --list    列出所有可安装的技能
  ./install --remove  卸载已安装的技能
  ./install --help    显示此帮助信息

技能安装位置：$CLAUDE_SKILLS_DIR
EOF
}

list_skills() {
  echo "可安装的技能："
  echo ""
  for skill_dir in "$SKILLS_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name=$(basename "$skill_dir")
      # 提取 description 字段
      desc=$(grep -m1 '^description:' "$skill_dir/SKILL.md" | sed 's/^description: *"//' | sed 's/"$//' | cut -c1-60)
      echo "  • $skill_name"
      if [ -n "$desc" ]; then
        echo "    $desc..."
      fi
    fi
  done
}

install_skills() {
  echo "正在安装 sense 技能包..."
  echo ""

  # 确保目标目录存在
  mkdir -p "$CLAUDE_SKILLS_DIR"

  installed=0
  skipped=0

  for skill_dir in "$SKILLS_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name=$(basename "$skill_dir")
      target="$CLAUDE_SKILLS_DIR/$skill_name"

      if [ -d "$target" ]; then
        warn "已存在，跳过：$skill_name（如需更新请先运行 ./install --remove）"
        skipped=$((skipped + 1))
      else
        # 创建软链接（方便后续更新）
        ln -s "$skill_dir" "$target"
        info "已安装：$skill_name"
        installed=$((installed + 1))
      fi
    fi
  done

  echo ""
  echo "完成！安装了 $installed 个技能，跳过 $skipped 个（已存在）。"
  echo ""
  echo "在 Claude Code 中使用技能："
  echo "  • sense-human-loop：开始 SENSE 深度思考循环"
  echo "  • sense-ai-loop：驱动 AI 自动完成软件开发（plan → doing → learning）"
  echo ""
  echo "触发方式：在对话中直接描述需求，Claude 会自动识别并使用对应技能。"
  echo "例如："
  echo "  「帮我用 SENSE 分析这个问题：……」"
  echo "  「用 sense 实现这个需求」"
  echo "  「sense loop」"
}

remove_skills() {
  echo "正在卸载 sense 技能包..."
  echo ""

  removed=0

  for skill_dir in "$SKILLS_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name=$(basename "$skill_dir")
      target="$CLAUDE_SKILLS_DIR/$skill_name"

      if [ -L "$target" ]; then
        rm "$target"
        info "已卸载：$skill_name"
        removed=$((removed + 1))
      elif [ -d "$target" ]; then
        warn "跳过（非软链接，请手动删除）：$target"
      fi
    fi
  done

  if [ $removed -eq 0 ]; then
    warn "没有找到已安装的 sense 技能。"
  else
    echo ""
    echo "完成！已卸载 $removed 个技能。"
  fi
}

# 解析参数
case "${1:-}" in
  --help|-h)
    usage
    ;;
  --list|-l)
    list_skills
    ;;
  --remove|-r)
    remove_skills
    ;;
  "")
    install_skills
    ;;
  *)
    error "未知选项：$1"
    echo ""
    usage
    exit 1
    ;;
esac
