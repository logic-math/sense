#!/usr/bin/env bash
# install — 将 sense 技能包安装到 Claude Code 和 OpenClaw，并将 sense CLI 安装到 PATH
# 用法：./install [选项]
#   --list     列出所有可安装的技能
#   --remove   卸载已安装的技能
#   --help     显示帮助信息

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_DIR="$SCRIPT_DIR/skills"
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
OPENCLAW_SKILLS_DIR="$HOME/.openclaw/workspace/skills"
BIN_SOURCE="$SCRIPT_DIR/bin/sense"
BIN_TARGET="$HOME/.local/bin/sense"

# 颜色输出
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

info()    { echo -e "${GREEN}[✓]${NC} $1"; }
warn()    { echo -e "${YELLOW}[!]${NC} $1"; }
error()   { echo -e "${RED}[✗]${NC} $1"; }

usage() {
  cat <<EOF
sense 技能包安装脚本

用法：
  ./install           安装所有技能到 Claude Code 和 OpenClaw
  ./install --list    列出所有可安装的技能
  ./install --remove  卸载已安装的技能
  ./install --help    显示此帮助信息

技能安装位置：
  Claude Code: $CLAUDE_SKILLS_DIR
  OpenClaw:    $OPENCLAW_SKILLS_DIR
CLI 安装位置：$BIN_TARGET
EOF
}

list_skills() {
  echo "可安装的技能："
  echo ""
  for skill_dir in "$SKILLS_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name=$(basename "$skill_dir")
      # 提取 description 字段
      desc=$(grep -m1 '^description:' "$skill_dir/SKILL.md" | sed 's/^description: *"//' | sed 's/"$//' | cut -c1-60)
      echo "  • $skill_name"
      if [ -n "$desc" ]; then
        echo "    $desc..."
      fi
    fi
  done
}

install_cli() {
  echo "正在安装 sense CLI..."

  if [ ! -f "$BIN_SOURCE" ]; then
    warn "未找到 bin/sense，跳过 CLI 安装（可运行 go build -o bin/sense ./cmd/sense 编译）"
    return
  fi

  mkdir -p "$(dirname "$BIN_TARGET")"

  if [ -L "$BIN_TARGET" ]; then
    rm "$BIN_TARGET"
  fi

  ln -s "$BIN_SOURCE" "$BIN_TARGET"
  info "CLI 已安装：$BIN_TARGET -> $BIN_SOURCE"

  # 检查 ~/.local/bin 是否在 PATH 中
  if ! echo "$PATH" | tr ':' '\n' | grep -qx "$HOME/.local/bin"; then
    warn "~/.local/bin 不在 PATH 中，请在 shell 配置文件（~/.zshrc 或 ~/.bashrc）中添加："
    echo "       export PATH=\"\$HOME/.local/bin:\$PATH\""
  fi
}

install_skills() {
  echo "正在安装 sense 技能包..."
  echo ""

  # 确保目标目录存在
  mkdir -p "$CLAUDE_SKILLS_DIR"
  mkdir -p "$OPENCLAW_SKILLS_DIR"

  installed_claude=0
  installed_openclaw=0
  skipped=0

  for skill_dir in "$SKILLS_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name=$(basename "$skill_dir")
      target_claude="$CLAUDE_SKILLS_DIR/$skill_name"
      target_openclaw="$OPENCLAW_SKILLS_DIR/$skill_name"

      # 安装到 Claude Code
      if [ -d "$target_claude" ]; then
        warn "Claude Code 已存在，跳过：$skill_name"
        skipped=$((skipped + 1))
      else
        ln -s "$skill_dir" "$target_claude"
        info "Claude Code 已安装：$skill_name"
        installed_claude=$((installed_claude + 1))
      fi

      # 安装到 OpenClaw
      if [ -d "$target_openclaw" ]; then
        warn "OpenClaw 已存在，跳过：$skill_name"
      else
        ln -s "$skill_dir" "$target_openclaw"
        info "OpenClaw 已安装：$skill_name"
        installed_openclaw=$((installed_openclaw + 1))
      fi
    fi
  done

  echo ""
  echo "完成！"
  echo "  Claude Code: 安装了 $installed_claude 个技能"
  echo "  OpenClaw:    安装了 $installed_openclaw 个技能"
  echo "  跳过: $skipped 个（已存在）"
  echo ""

  install_cli

  echo ""
  echo "在 Claude Code / OpenClaw 中使用技能："
  echo "  • sense-human-loop：开始 SENSE 深度思考循环"
  echo "  • sense-ai-loop：驱动 AI 自动完成软件开发（plan → doing → learning）"
  echo ""
  echo "触发方式：在对话中直接描述需求，AI 会自动识别并使用对应技能。"
  echo "例如："
  echo "  「帮我用 SENSE 分析这个问题：……」"
  echo "  「用 sense 实现这个需求」"
  echo "  「sense loop」"
}

remove_skills() {
  echo "正在卸载 sense 技能包..."
  echo ""

  removed_claude=0
  removed_openclaw=0

  for skill_dir in "$SKILLS_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name=$(basename "$skill_dir")
      target_claude="$CLAUDE_SKILLS_DIR/$skill_name"
      target_openclaw="$OPENCLAW_SKILLS_DIR/$skill_name"

      # 卸载 Claude Code
      if [ -L "$target_claude" ]; then
        rm "$target_claude"
        info "Claude Code 已卸载：$skill_name"
        removed_claude=$((removed_claude + 1))
      elif [ -d "$target_claude" ]; then
        warn "Claude Code 跳过（非软链接，请手动删除）：$target_claude"
      fi

      # 卸载 OpenClaw
      if [ -L "$target_openclaw" ]; then
        rm "$target_openclaw"
        info "OpenClaw 已卸载：$skill_name"
        removed_openclaw=$((removed_openclaw + 1))
      elif [ -d "$target_openclaw" ]; then
        warn "OpenClaw 跳过（非软链接，请手动删除）：$target_openclaw"
      fi
    fi
  done

  # 卸载 CLI
  if [ -L "$BIN_TARGET" ]; then
    rm "$BIN_TARGET"
    info "CLI 已卸载：$BIN_TARGET"
  fi

  if [ $removed_claude -eq 0 ] && [ $removed_openclaw -eq 0 ]; then
    warn "没有找到已安装的 sense 技能。"
  else
    echo ""
    echo "完成！"
    echo "  Claude Code: 已卸载 $removed_claude 个技能"
    echo "  OpenClaw:    已卸载 $removed_openclaw 个技能"
  fi
}

# 解析参数
case "${1:-}" in
  --help|-h)
    usage
    ;;
  --list|-l)
    list_skills
    ;;
  --remove|-r)
    remove_skills
    ;;
  "")
    install_skills
    ;;
  *)
    error "未知选项：$1"
    echo ""
    usage
    exit 1
    ;;
esac
